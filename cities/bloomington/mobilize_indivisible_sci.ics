BEGIN:VEVENT
SUMMARY:ISCI Postcard Party for Swing States
DTSTART;TZID=EDT;VALUE=DATE-TIME:20260412T150000
DTEND;TZID=EDT;VALUE=DATE-TIME:20260412T170000
UID:mobilize-921621-5874765@mobilize.us
