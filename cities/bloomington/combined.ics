X-SOURCE-URLS:{"IU Hamilton Lugar School": "https://events.iu.edu/live/events/2043004-21jpsi-iks-arrington", "IU Maurer School of Law": "https://events.iu.edu/live/events/2043004-21jpsi-iks-arrington"}
X-SOURCE-URLS:{"IU Hamilton Lugar School": "https://events.iu.edu/live/events/2043004-21jpsi-iks-arrington"}
X-SOURCE-ID:iu_hamilton_lugar
X-SOURCE:IU Hamilton Lugar School, IU Maurer School of Law
DTSTART:20260327T160000Z
DTEND:20260327T170000Z
