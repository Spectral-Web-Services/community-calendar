BEGIN:VEVENT
SUMMARY:Variety Night - Live Painting!
DTSTART;TZID=UTC;VALUE=DATE-TIME:20260417T230000Z
DTEND;TZID=UTC;VALUE=DATE-TIME:20260418T010000Z
UID:79cc680f69b25a6c71e31d4568f6757c@northwestern.edu
DESCRIPTION:Join in us for weekly Variety Nights on Next Up! Stage! from 6
