			3rd day		</option>
				<option value="4">
			4th day		</option>
				<option value="5">
			5th day		</option>
				<option value="6">
			6th day		</option>
				<option value="7">
			7th day		</option>
				{{/tribe_recurrence_select}}
	</select>
</div>
