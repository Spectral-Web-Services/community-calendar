								data-single="event"
								data-plural="events"
								value="{{ custom.type }}"
						>
						<a
							data-value="Daily"
							class="tribe-button-field"
							href="#"
							data-singular="day"
						>Daily</a>
						<a
							data-value="Weekly"
							class="tribe-button-field"
							href="#"
						>Weekly</a>
						<a
							data-value="Monthly"
							class="tribe-button-field"
							href="#"
						>Monthly</a>
						<a
							data-value="Yearly"
							class="tribe-button-field"
