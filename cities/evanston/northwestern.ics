BEGIN:VEVENT
SUMMARY:Seth Alexander\, Miguel Flores-Padilla\, Boss Lee\, and Everest Li
 \, saxophone
DTSTART;TZID=UTC;VALUE=DATE-TIME:20260426T210000Z
DTEND;TZID=UTC;VALUE=DATE-TIME:20260426T223000Z
UID:685dfaaf617329bc8ca5bd8033baa92e@northwestern.edu
