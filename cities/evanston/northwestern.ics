DTSTART;TZID=UTC;VALUE=DATE-TIME:20260411T193000Z
DTEND;TZID=UTC;VALUE=DATE-TIME:20260411T210000Z
UID:3c75a3ccc69bee6bc227a772c1c73582@northwestern.edu
DESCRIPTION:Bachelor of Music \nStudent of David Bilger \nMichael James 
