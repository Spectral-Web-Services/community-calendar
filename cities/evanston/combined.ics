BEGIN:VEVENT
X-SOURCE-URLS:{"Winnetka Northfield Library": "https://www.wnpld.org/event/caving-adventures-35843"}
X-SOURCE-ID:winnetka_northfield_library
X-SOURCE:Winnetka Northfield Library
UID:35843
DTSTAMP:20260315T025452Z
SUMMARY:The Alamo and The Republic of Tejas
URL;VALUE=URI:https://www.wnpld.org/event/caving-adventures-35843
STATUS:CONFIRMED
CREATED:20251112T165723Z
LAST-MODIFIED:20260211T161510Z
DESCRIPTION:This presentation reexamines the Alamo and the Republic of Teja
 s\, cutting through familiar myths with historical context and turning a s
 harp eye toward American legend-making. It explores how rebellion\, expans
 ion\, and selective memory shaped nationalism\, borders\, and Texan cultur
 e—often at Mexico’s expense. The Alamo\, The Republic of Tejas\, and N
 ever Forgetting invites audiences to remember the past a little less comfo
 rtably\, and a lot more honestly.
CATEGORIES:History
DTSTART:20260401T000000Z
DTEND:20260401T010000Z
LOCATION:US
END:VEVENT
