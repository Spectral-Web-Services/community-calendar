DTEND;TZID=America/Chicago:20270627T090000
CREATED:20260112T230617Z
LAST-MODIFIED:20260302T193245Z
RRULE:FREQ=YEARLY;BYMONTH=6;BYDAY=-1SU
X-TEAMUP-STATUS:CHANGES PENDING!
X-TEAMUP-PACE:Fast
X-TEAMUP-DISTANCE:60 miles
X-TEAMUP-START-LOCATION:Bristol Woods County Park\, Wisconsin
X-TEAMUP-LEADER:Peter Glaser
END:VEVENT
